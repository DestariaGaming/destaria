{
  "name": "@destaria/authoring",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "fmt:check": "oxfmt --check package.json tsconfig.json src",
    "fmt:fix": "oxfmt --write package.json tsconfig.json src",
    "lint:check": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix",
    "test": "bun test",
    "check:all": "bun run typecheck && bun run fmt:check && bun run lint:check",
    "fix:all": "bun run fmt:fix && bun run lint:fix && bun run typecheck"
  },
  "dependencies": {
    "@destaria/package-format": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
